local a = cloneref(game:GetService("Players"))
local b = a.LocalPlayer:WaitForChild("PlayerGui")
local c = workspace:FindFirstChild("NPCFolders")
local d = c and c:FindFirstChild("EnemyFolder")
local function e()
	local f = d and d:FindFirstChild("Chronos")
	local g = f and f:FindFirstChild("Humanoid")
	if g then
		return g.Health <= g.MaxHealth * 0.56 and 7.5 or 14.5
	end;
	return 14.5
end;
b.ChildAdded:Connect(function(h)
	if h.Name ~= "ClockQuiz" then
		return
	end;
	for i, j in ipairs(h:GetDescendants()) do
		if j:IsA("GuiObject") then
			j.Visible = false
		end
	end;
	if h:IsA("ScreenGui") then
		h.Enabled = false
	end;
	task.wait(e())
	local k = h:FindFirstChild("Answer")
	if k then
		k:FireServer(true)
	end;
	h:Destroy()
end)
